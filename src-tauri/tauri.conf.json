{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Longchamp-Budget",
    "version": "1.0.0",
    "identifier": "longchamp.budget.app",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Longchamp Budget",
                "width": 1100,
                "height": 600,
                "dragDropEnabled": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "icons/icon.png"
        ]
    }
}